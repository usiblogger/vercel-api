{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "/api/pos(/?.*)", "dest": "/api/pos.php" },
    { "src": "/api/todos(/?.*)", "dest": "/api/todos.php" },
    { "src": "/api/files(/?.*)", "dest": "/api/files.php" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
