# ── Database ──
# Driver: sqlite or supabase
DB_DRIVER=sqlite

# SQLite (used when DB_DRIVER=sqlite)
# SQLITE_PATH=data/todos.db

# Supabase (used when DB_DRIVER=supabase)
# Get these from: Project Settings → API
# SUPABASE_URL=https://gqimkvmjublojwqmsbwz.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon...

# ── File Storage ──
# Driver: local or supabase
STORAGE_DRIVER=local

# Local filesystem (used when STORAGE_DRIVER=local)
# UPLOAD_DIR=uploads

# Supabase Storage (used when STORAGE_DRIVER=supabase)
# Uses SUPABASE_URL and SUPABASE_KEY from above
# For storage operations, add the service_role key:
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role...
# ⚠ NEVER commit the service key to git. Set it in Vercel dashboard.
